# Plain HTTP mode. Used by CI smoke tests and local dev where no cert is available.
{
    admin off
    auto_https off
}

:80 {
    encode zstd gzip

    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        # HSTS + CSP + Secure cookies: wired in slice #11 alongside TLS.
    }

    reverse_proxy web:3000 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }
}
