# Telecom Service Mapping — environment template
# Copy to .env and fill in real values. Never commit .env.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Source Postgres (read-only; LLDP + customer + site data) ---
# Use a dedicated read-only role; see README "Quick start" for the role SQL.
DATABASE_URL_SOURCE=postgres://lldp_readonly:CHANGE_ME@source-db-host:5432/source_db

# --- App Postgres 13 (users, sessions, saved_views, ingestion_runs) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=app
DATABASE_URL=postgres://app:CHANGE_ME@postgres:5432/app

# --- Neo4j 5 (graph store) ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# --- Auth.js v5 (Credentials provider, DB sessions) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME
NEXTAUTH_URL=https://ts-mapping.example.com
# Auth.js v5 requires this whenever Next.js runs behind a reverse proxy
# (Caddy, in our case) on a non-Vercel host. Without it Auth.js refuses
# to trust the forwarded Host header and login callbacks return 400.
AUTH_TRUST_HOST=true

# --- Ingestor (nightly cron schedule) ---
INGEST_CRON=0 2 * * *
# Mode: 'full' (real ingest; requires DATABASE_URL_SOURCE reachable)
#     | 'smoke' (migrations only; used by CI and tracer-bullet when no source DB)
INGEST_MODE=full

# --- Caddy (reverse proxy + TLS) ---
# Mode selects which Caddyfile is active at container start.
#   http      — plain :80 (dev, CI smoke tests). No TLS, no HSTS.
#   internal  — Caddy's internal CA. LAN deploys; install Caddy root CA on clients.
#   tailscale — cert sourced from the host's Tailscale daemon.
#   acme      — Let's Encrypt via HTTP-01. Requires public DNS and open :80/:443.
CADDY_TLS_MODE=acme

# Fully-qualified host the stack is reachable at. MUST match NEXTAUTH_URL host.
CADDY_DOMAIN=ts-mapping.example.com

# Contact email for Let's Encrypt registration + expiry warnings. Required for acme mode.
CADDY_ACME_EMAIL=ops@example.com

# --- ClickHouse (issue #67 — ISIS-cost ingestion; optional) ---
# When CLICKHOUSE_URL is unset the ingestor degrades gracefully and skips
# the ISIS-cost stage; nightly LLDP/DWDM runs still complete. When set, the
# other three CH keys (USER, PASSWORD, DATABASE) become required as a group.
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME
CLICKHOUSE_DATABASE=lldp_data

# Optional CH tunables:
CLICKHOUSE_ISIS_TABLE=isis_cost            # override if V2 points at a different table
CLICKHOUSE_TIMEOUT_MS=10000                # per-query timeout (ms)
